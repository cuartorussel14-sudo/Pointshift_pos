            }                // Get new stream with explicit constraints

        } catch (error) {                videoStream = await navigator.mediaDevices.getUserMedia({

            console.error('Error updating expiry date:', error);                    video: {

            showStatus('Error updating expiry date', true);                        deviceId: selectedCamera ? { exact: selectedCamera } : undefined,

        }                        width: { min: 640, ideal: 1280, max: 1920 },

    };                        height: { min: 480, ideal: 720, max: 1080 },

