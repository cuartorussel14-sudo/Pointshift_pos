    // Event Listeners    function updateStatus(message, isError = false) {

    document.getElementById('startButton').addEventListener('click', startScanner);        if (!statusIndicator) return;

    document.getElementById('resetButton').addEventListener('click', stopScanner);        statusIndicator.textContent = message;

        statusIndicator.style.display = 'block';

    // Expose necessary functions to window        statusIndicator.style.backgroundColor = isError ? 'rgba(220,53,69,0.9)' : 'rgba(0,0,0,0.7)';

    window.updateExpiry = async function(productId) {        setTimeout(() => {

        const newExpiry = document.getElementById('expiryDateInput').value;            statusIndicator.style.display = 'none';

        if (!newExpiry) {        }, 3000);

            showStatus('Please select a valid expiry date', true);    }

            return;

        }    async function startBarcodeScanner() {

        try {

        try {            console.log('Initializing scanner...');

            const response = await fetch('update_product.php', {            updateStatus('Initializing camera...');

