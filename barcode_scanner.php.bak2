                })                return;

            });            }



            const data = await response.json();            // Stop any existing stream

            if (data.success) {            if (videoStream) {

                showStatus('Expiry date updated successfully');                videoStream.getTracks().forEach(track => track.stop());

                displayProductInfo(data.product);            }

