<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect direct requests to the classic logout.php to the new signout.php
    RewriteRule ^logout\.php$ /point-shift_pos-system/signout.php [R=302,L]
</IfModule>

# Fallback for servers without mod_rewrite
RedirectMatch 302 ^/point-shift_pos-system/logout\.php$ /point-shift_pos-system/signout.php

